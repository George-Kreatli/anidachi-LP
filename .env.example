# Kreatli Email CRM + Bloü (same login cookie; production: set both; dev uses safe fallbacks only in NODE_ENV=development)
KREATLI_CRM_PASSWORD=
KREATLI_CRM_SESSION_SECRET=

# Optional: absolute path to CRM data (defaults to ./crm-data). Same for Next app and `npm run crm`.
# CRM_DATA_DIR=

# Gmail send (Kreatli CRM) — create OAuth "Web application" in Google Cloud Console
# Authorized redirect URI must match exactly the URL you use in the browser, e.g.
#   http://localhost:3003/api/kreatli-crm/gmail/callback   (default dev port in package.json)
# Only set this if the app cannot infer the public URL (reverse proxy / custom host):
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3003/api/kreatli-crm/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Sender name recipients see. Gmail ignores MIME "From" names for API mail — we update your Gmail
# "Send mail as" display name via the Settings API (needs extra OAuth scope). After upgrading CRM:
# disconnect Gmail on the CRM page → Connect again → add gmail.settings.basic on Google’s consent screen if asked.
# Set on every deployed host (e.g. Vercel) if you rely on API sync; restart after changes.
# GOOGLE_GMAIL_SENDER_NAME=Heorhi Talochka
# Optional: send as this address instead of the OAuth profile email. Must exactly match a row under
# Gmail → Settings → Accounts → Send mail as (wrong value = wrong or missing display name for recipients).
# GOOGLE_GMAIL_FROM_EMAIL=you@yourdomain.com
